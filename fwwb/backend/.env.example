# 智能小车后端环境变量配置
# 复制此文件为 .env 并修改配置

# MySQL配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=smart_car

# TCP服务器配置 (小程序连接)
TCP_HOST=0.0.0.0
TCP_PORT=8888

# UDP配置 (连接Hi3861小车)
UDP_PORT=7788

# ============ 数字孪生大屏 SSE 推送 ============
# 后端周期性把 dashboard 快照通过 SSE (text/event-stream) 推送到前端大屏
# DASHBOARD_STREAM_ENABLED=true
# DASHBOARD_STREAM_INTERVAL=1.0   # 推送周期（秒）
# DASHBOARD_STREAM_HEARTBEAT=15   # 心跳周期（秒），防止代理/浏览器关闭空闲连接

# 数据存储间隔(秒)
DATA_SAVE_INTERVAL=1

# 最大TCP客户端连接数
MAX_TCP_CLIENTS=10

# IMU 配置 (Yesense H30)
# 支持模式: tcp（网口版直连后端）, serial（USB串口版直连后端）, udp_passive（Hi3861 I2C读取后UDP JSON透传）
# IMU_ENABLED=true
# IMU_MODE=udp_passive
# IMU_TCP_HOST=192.168.1.200
# IMU_TCP_PORT=8899
# IMU_SERIAL_PORT=/dev/ttyUSB0
# IMU_SERIAL_BAUDRATE=460800

# ============ 视觉识别配置 ============
# 整合自 sjsb 项目，提供障碍物检测 + 工业计数器识别。
# 默认关闭，启用前需准备模型文件至 VISION_MODELS_DIR (默认 backend/models/)
# VISION_ENABLED=true
# VISION_CAMERA_TYPE=esp32              # none / usb / esp32
# VISION_CAMERA_INDEX=0
# VISION_FRAME_WIDTH=320
# VISION_FRAME_HEIGHT=240
# VISION_FPS=1
# VISION_ESP32_IP=192.168.137.213
# VISION_ESP32_CAPTURE_PATH=/capture
# VISION_ESP32_TIMEOUT=3.0
# OpenMV 串口配置（VISION_CAMERA_TYPE=openmv 时启用）
# 板侧需运行 tools/openmv/openmv_camera.py 固件
# VISION_OPENMV_PORT=                    # 留空 = 自动扫描 USB/CDC/ACM；也可写 /dev/ttyACM0
# VISION_OPENMV_BAUDRATE=115200
# VISION_OPENMV_TIMEOUT=3.0
# 启动后端时自动弹出 OpenMV 调试 GUI 子进程
# 在 GUI 里点「连接」「开始计数器识别」，识别到的数字通过 HTTP 上报后端
# 由后端 SSE 推送到大屏前端的「货物感应计数」面板
# VISION_OPENMV_GUI=true
# VISION_MODELS_DIR=./models
# VISION_OBSTACLE_MODEL=yolo11s.pt
# VISION_DIGIT_PANEL_MODEL=digit_panel_yolov8s.pt
# VISION_CRNN_MODEL=best_crnn.pth
# VISION_OBSTACLE_CONF=0.05
# VISION_COUNTER_CONF=0.3
# VISION_DEVICE=auto                    # auto / cpu / cuda
# VISION_OBSTACLE_INTERVAL=1.0
# VISION_COUNTER_INTERVAL=1.0
# VISION_PERSIST_INTERVAL=5.0
# VISION_PERSIST_IMAGE=false

# ============ 联动控制配置（LinkageController） ============
# 后端集中决策三条传感器联动：
#   PIR(AP3216C) → LED 自动照明
#   温湿度 → 风扇自动启停（带回滞）
#   危气 alertLevel → AW2013 RGB（黄/红/红闪烁/灭）
# LINKAGE_ENABLED=true
# LINKAGE_TICK_SECONDS=1.0
# 风扇阈值（双门限回滞，避免临界抖动）
# FAN_TEMP_ON=32.0
# FAN_TEMP_OFF=30.0
# FAN_HUMI_ON=80.0
# FAN_HUMI_OFF=75.0
# PIR 人体判定（AP3216C ps/ir 通道，需现场标定）
# IR_PS_THRESHOLD=200
# IR_IR_THRESHOLD=100
# IR_DEBOUNCE_ON=2
# IR_DEBOUNCE_OFF=5
# RGB 闪烁频率（critical 等级使用，Hz）
# RGB_BLINK_HZ=1.0
# 手动控制后该路自动联动静默秒数
# MANUAL_OVERRIDE_TTL=30
# 危气分级阈值（webapp 设置页可在线修改，这里只是初始值）
# CO2_WARNING=800
# CO2_DANGER=1000
# TVOC_WARNING=600
# TVOC_DANGER=900
# GASMIC_WARNING=300
# GASMIC_DANGER=500
# DISTANCE_WARNING=30
# DISTANCE_DANGER=15
