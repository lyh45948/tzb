# 智能小车后端环境变量配置
# 复制此文件为 .env 并修改配置

# MySQL配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=smart_car

# TCP服务器配置 (小程序连接)
TCP_HOST=0.0.0.0
TCP_PORT=8888

# UDP配置 (连接Hi3861小车)
UDP_PORT=7788

# 数据存储间隔(秒)
DATA_SAVE_INTERVAL=1

# 最大TCP客户端连接数
MAX_TCP_CLIENTS=10

# IMU 配置 (Yesense H30)
# 支持模式: tcp（网口版直连后端）, serial（USB串口版直连后端）, udp_passive（Hi3861 I2C读取后UDP JSON透传）
# IMU_ENABLED=true
# IMU_MODE=udp_passive
# IMU_TCP_HOST=192.168.1.200
# IMU_TCP_PORT=8899
# IMU_SERIAL_PORT=/dev/ttyUSB0
# IMU_SERIAL_BAUDRATE=460800
