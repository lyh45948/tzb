/* components/sensor-gauge/sensor-gauge.wxss */
.gauge-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.gauge-circle {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gauge-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.gauge-value {
  font-size: 24px;
  font-weight: 600;
  color: #333333;
  line-height: 1.2;
}

.gauge-unit {
  font-size: 12px;
  color: #666666;
}

.gauge-title {
  font-size: 13px;
  color: #666666;
  margin-top: 8rpx;
  text-align: center;
}
