/* app.wxss - 智慧农业全局样式 */

/* 农业主题配色 */
page {
  --primary: #4CAF50;
  --primary-light: #81C784;
  --primary-dark: #388E3C;
  --warning: #FF9800;
  --danger: #F44336;
  --info: #2196F3;
  --bg: #F5F5F5;
  --card: #FFFFFF;
  --text: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border: #E0E0E0;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: var(--text);
  min-height: 100vh;
}

/* 容器 */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: var(--card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 12px;
}

.status-tag.success {
  background-color: rgba(76, 175, 80, 0.1);
  color: var(--primary);
}

.status-tag.warning {
  background-color: rgba(255, 152, 0, 0.1);
  color: var(--warning);
}

.status-tag.danger {
  background-color: rgba(244, 67, 54, 0.1);
  color: var(--danger);
}

.status-tag.info {
  background-color: rgba(33, 150, 243, 0.1);
  color: var(--info);
}

/* 传感器网格 */
.sensor-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.sensor-item {
  background-color: var(--card);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.sensor-value {
  font-size: 32px;
  font-weight: 600;
  color: var(--primary);
}

.sensor-label {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.sensor-unit {
  font-size: 14px;
  color: var(--text-light);
}

/* 控制面板 */
.control-panel {
  background-color: var(--card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.control-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.control-item:last-child {
  border-bottom: none;
}

.control-label {
  font-size: 15px;
  color: var(--text);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 15px;
  font-weight: 500;
}

.btn-primary {
  background-color: var(--primary);
  color: #FFFFFF;
}

.btn-secondary {
  background-color: var(--bg);
  color: var(--text);
}

.btn-danger {
  background-color: var(--danger);
  color: #FFFFFF;
}

/* 开关样式覆盖 */
.switch-active {
  background-color: var(--primary) !important;
}

/* 滑块样式覆盖 */
.slider-active {
  background-color: var(--primary) !important;
}

/* 预警横幅 */
.alert-banner {
  background-color: rgba(244, 67, 54, 0.1);
  border-left: 6rpx solid var(--danger);
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
}

.alert-banner.warning {
  background-color: rgba(255, 152, 0, 0.1);
  border-left-color: var(--warning);
}

.alert-text {
  font-size: 13px;
  color: var(--danger);
}

.alert-banner.warning .alert-text {
  color: var(--warning);
}

/* 连接状态 */
.connection-status {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: var(--card);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.connection-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.connection-dot.online {
  background-color: var(--primary);
}

.connection-dot.offline {
  background-color: var(--text-light);
}

.connection-text {
  font-size: 14px;
  color: var(--text-secondary);
}

/* 图表容器 */
.chart-container {
  background-color: var(--card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

/* 历史记录列表 */
.history-list {
  background-color: var(--card);
  border-radius: 16rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.history-item:last-child {
  border-bottom: none;
}

.history-time {
  font-size: 12px;
  color: var(--text-light);
}

.history-value {
  font-size: 14px;
  color: var(--text);
}

/* 设置项 */
.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: var(--card);
  margin-bottom: 2rpx;
}

.settings-label {
  font-size: 15px;
  color: var(--text);
}

.settings-value {
  font-size: 14px;
  color: var(--text-secondary);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-light);
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 14px;
}

/* 动画 */
@keyframes pulse {
  0% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
  100% {
    opacity: 1;
  }
}

.pulse {
  animation: pulse 2s ease-in-out infinite;
}

/* 传感器颜色 */
.sensor-temp {
  color: #F44336;
}

.sensor-humidity {
  color: #2196F3;
}

.sensor-light {
  color: #FFC107;
}

.sensor-soil {
  color: #795548;
}

.sensor-co2 {
  color: #9C27B0;
}
