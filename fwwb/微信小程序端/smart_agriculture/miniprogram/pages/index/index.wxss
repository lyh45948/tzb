/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 状态卡片 */
.status-card {
  background-color: var(--card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

 .status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

 .status-left {
  display: flex;
  align-items: center;
 }
 .status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}
 .status-dot.online {
  background-color: #4CAF50;
}
 .status-dot.offline {
  background-color: #999;
}
 .status-text {
  font-size: 14px;
  color: #666;
}
 .status-right {
  display: flex;
  align-items: center;
 }
 .demo-label {
  font-size: 12px;
  color: #999;
    margin-right: 12rpx;
}

/* 仪表盘区域 */
.gauges-section {
  margin-top: 20rpx;
}
 .gauge-row {
  display: flex;
  justify-content: space-around;
    margin-bottom: 20rpx;
}
 .gauge-item {
  flex: 1;
  display: flex;
    justify-content: center;
    min-width: 160rpx;
 }
 .co2-item {
    flex: none;
    display: flex;
    justify-content: center;
  }

/* 预警区域 */
.alert-section {
  margin-top: 20rpx;
}
 .alert-banner {
  background-color: rgba(244, 67, 54, 0.1);
    border-left: 4rpx solid #F44336;
    padding: 16rpx 20rpx;
    margin-bottom: 12rpx;
    border-radius: 8rpx;
}
 .alert-text {
    font-size: 13px;
    color: #F44336;
  }

/* 设置按钮 */
.settings-btn {
  position: fixed;
  bottom: 40rpx;
  right: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #4CAF50;
  border-radius: 50%;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}
 .settings-icon {
    font-size: 24px;
    color: white;
  }
 .settings-text {
    font-size: 12px;
    color: white;
    margin-top: 4rpx;
  }
