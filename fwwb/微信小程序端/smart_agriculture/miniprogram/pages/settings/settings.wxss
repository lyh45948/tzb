/* pages/settings/settings.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
}
.nav-left {
  display: flex;
  align-items: center;
}
.back-icon {
  font-size: 18px;
  color: #4CAF50;
  margin-right: 8rpx;
}
.back-text {
  font-size: 15px;
  color: #4CAF50;
}
.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}
.nav-right {
  width: 50rpx;
}

/* 设置区块 */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}
.setting-label {
  font-size: 14px;
  color: #666;
}

/* 阈值项 */
.threshold-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.threshold-item:last-child {
  border-bottom: none;
}
.threshold-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.threshold-value {
  margin-top: 8rpx;
}
.value-text {
  font-size: 14px;
  font-weight: 600;
  color: #4CAF50;
  margin-bottom: 8rpx;
  display: block;
}

/* 按钮区域 */
.button-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.save-btn {
  width: 100%;
  background-color: #4CAF50;
  color: white;
  border: none;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 12rpx;
}
.reset-btn {
  width: 100%;
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 16px;
}
