/* pages/monitor/monitor.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 时间范围选择器 */
.time-range-bar {
  display: flex;
  justify-content: space-around;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.range-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 14px;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}
.range-item.active {
  background-color: #4CAF50;
  color: #fff;
}

/* 数据卡片 */
.data-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.data-card {
  flex: 1;
  min-width: 160rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.card-header {
  margin-bottom: 12rpx;
}
.card-title {
  font-size: 12px;
  color: #999;
}
.card-value {
  font-size: 28px;
  font-weight: 600;
  margin: 8rpx 0;
}
.card-chart {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.chart-placeholder {
  width: 100%;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.chart-text {
  font-size: 12px;
  color: #999;
}

/* 预警历史 */
.alert-history {
  margin-top: 20rpx;
}
.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}
.alert-list {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}
.alert-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.alert-item:last-child {
  border-bottom: none;
}
.alert-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: rgba(244, 67, 54, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}
.icon-text {
  color: #F44336;
  font-size: 14px;
  font-weight: 600;
}
.alert-content {
  flex: 1;
}
.alert-message {
  font-size: 14px;
  color: #333;
  margin-bottom: 4rpx;
}
.alert-time {
  font-size: 12px;
  color: #999;
}
.no-alert {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
}
.no-alert-text {
  font-size: 14px;
  color: #999;
}
