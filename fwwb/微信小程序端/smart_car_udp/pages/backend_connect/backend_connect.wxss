/* pages/backend_connect/backend_connect.wxss */

.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f8ff 0%, #ffffff 100%);
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #323233;
}

/* 状态栏 */
.status-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.status-bar.connected {
  background: #e8f5e9;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #969799;
}

.status-bar.connected .status-indicator {
  background: #07c160;
}

.status-text {
  font-size: 28rpx;
  color: #646566;
}

.status-bar.connected .status-text {
  color: #07c160;
  font-weight: 500;
}

/* 配置区块 */
.config-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #323233;
}

.section-title .hint {
  font-size: 24rpx;
  color: #969799;
  font-weight: normal;
  margin-left: auto;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #646566;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f7f8fa;
  border: 2rpx solid #ebedf0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #323233;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #1989fa;
  background: #fff;
}

/* 按钮组 */
.button-group {
  margin-top: 30rpx;
}

.button-group van-button {
  margin-bottom: 20rpx;
}

.button-group van-button:last-child {
  margin-bottom: 0;
}

/* 数据区块 */
.data-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

/* 数据网格 */
.data-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
  gap: 16rpx;
  width: 100%;
}

.data-item {
  flex: 1;
  min-width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.data-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1989fa;
}

.data-label {
  font-size: 22rpx;
  color: #969799;
  margin-top: 8rpx;
}

/* 说明区块 */
.info-section {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  background: #fafafa;
  border-radius: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.info-text {
  font-size: 24rpx;
  color: #969799;
  line-height: 1.6;
}
