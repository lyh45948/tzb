/* pages/agriculture/agriculture.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 顶部控制栏 */
.control-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.control-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.control-item .label {
  font-size: 28rpx;
  color: #666;
}

/* 章节标题 */
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 告警区域 */
.alerts-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
  margin-left: 0;
  margin-right: 0;
}

.alert-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.alert-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.alert-item.high-alert {
  background-color: #fff3f3;
  color: #ff4d4f;
  border-left: 4rpx solid #ff4d4f;
}

.alert-item.low-alert {
  background-color: #fff7e6;
  color: #fa8c16;
  border-left: 4rpx solid #fa8c16;
}

.alert-message {
  flex: 1;
}

/* 传感器数据区域 */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.sensor-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  width: 100%;
}

.sensor-card {
  flex: 1;
  min-width: calc(33.33% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 16rpx;
  transition: transform 0.2s;
  box-sizing: border-box;
}

.sensor-card:active {
  transform: scale(0.95);
}

.sensor-icon {
  margin-bottom: 12rpx;
}

.sensor-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.sensor-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.sensor-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 设置按钮 */
.settings-btn {
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}

/* 响应式布局 - 小屏幕适配 */
@media screen and (max-width: 375px) {
  .sensor-card {
    min-width: calc(50% - 10rpx);
  }
}