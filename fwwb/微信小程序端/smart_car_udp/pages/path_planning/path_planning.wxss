.container {
  background: linear-gradient(180deg, #e8f4ff 0%, #ffffff 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 40rpx;
}

/* 页面标题栏 */
.page-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  background: #ffffff;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(25, 137, 250, 0.1);
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #323233;
}

/* 演示模式状态提示 */
.demo-status-bar {
  background: linear-gradient(135deg, #fff7e6 0%, #fff3cd 100%);
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  border-left: 4rpx solid #ff9d00;
}

.demo-status-text {
  font-size: 26rpx;
  color: #ff9d00;
  font-weight: 500;
  margin-left: 12rpx;
}

.connection-bar {
  background: #fff;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.connection-info {
  display: flex;
  align-items: center;
}

.connection-text {
  font-size: 28rpx;
  margin-left: 12rpx;
  color: #646566;
}

.mode-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 20rpx;
}

.path-drawing-section {
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  overflow: hidden;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.shape-selection {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  background: #fafafa;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.shape-btn {
  margin: 0 !important;
  flex: 1;
  min-width: 0;
  font-size: 26rpx !important;
  color: #323233 !important;
  background-color: #fff !important;
  border: 1rpx solid #ebedf0 !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
  border-radius: 12rpx !important;
  font-weight: 500 !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.shape-btn:active {
  background-color: #f2f3f5 !important;
}

.canvas-wrapper {
  border-radius: 0;
  overflow: hidden;
}

.path-canvas {
  width: 100%;
  background: #fdfdfd;
}

.small-canvas {
  height: 220px;
}

.toolbar {
  padding: 24rpx 30rpx;
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.toolbar van-button {
  flex: 1;
  min-width: 0;
}

.hint {
  padding: 32rpx;
  text-align: center;
  color: #969799;
  font-size: 26rpx;
  line-height: 1.6;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.hint text {
  display: block;
}
