.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  background: linear-gradient(180deg, #e8f4ff 0%, #ffffff 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-sizing: border-box;
}

/* 页面标题栏 */
.page-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(25, 137, 250, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #323233;
}

/* 演示模式状态提示 */
.demo-status-bar {
  background: linear-gradient(135deg, #fff7e6 0%, #fff3cd 100%);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  border-left: 4rpx solid #ff9d00;
  box-shadow: 0 2rpx 8rpx rgba(255, 157, 0, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.demo-status-text {
  font-size: 24rpx;
  color: #ff9d00;
  font-weight: 500;
  margin-left: 12rpx;
}

/* 传感器 2x2 网格 */
.sensor-grid-main {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}

.sensor-grid-main.col-3 .sensor-card-mini {
  flex: 1;
  min-width: 0;
}

.sensor-card-mini {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.sensor-card-mini.temp { border-bottom: 4rpx solid #ff9d00; }
.sensor-card-mini.humi { border-bottom: 4rpx solid #1989fa; }
.sensor-card-mini.lux { border-bottom: 4rpx solid #ffd700; }

.sensor-card-mini.temp.hot { background: linear-gradient(180deg, #fff, #fff7e6); }
.sensor-card-mini.temp.cold { background: linear-gradient(180deg, #fff, #f0f5ff); }

/* 传感器图标 */
.sensor-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.sensor-icon-wrapper.temp-icon { background: #fff7e6; }
.sensor-icon-wrapper.humi-icon { background: #e8f4ff; }
.sensor-icon-wrapper.lux-icon { background: #fffbe6; }

.card-title {
  font-size: 24rpx;
  color: #969799;
  margin-bottom: 8rpx;
}

.card-value {
  display: flex;
  align-items: baseline;
}

.card-value .num {
  font-size: 44rpx;
  font-weight: bold;
  color: #323233;
}

.card-value .unit {
  font-size: 22rpx;
  color: #c8c9cc;
  margin-left: 4rpx;
}

/* 曲线图区域 */
.chart-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.chart-title-wrapper {
  display: flex;
  align-items: center;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #323233;
}

.chart-legend {
  display: flex;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 20rpx;
  color: #969799;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}

.dot.temp { background: #ff9d00; }
.dot.humi { background: #1989fa; }
.dot.lux  { background: #ffd700; }

.canvas-container {
  display: flex;
  position: relative;
  height: 200rpx;
}

/* 传感器网格 col-3 布局 */
.sensor-grid-main.col-3 {
  grid-template-columns: 1fr 1fr 1fr;
}

.axis-y {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  font-size: 18rpx;
  width: 50rpx;
  color: #969799;
}

.axis-left {
  text-align: right;
  padding-right: 8rpx;
  color: #ff9d00;
}

.axis-right {
  text-align: left;
  padding-left: 8rpx;
  color: #1989fa;
}

.env-chart-canvas {
  flex: 1;
  height: 100%;
}

/* 控制面板紧凑型 */
.control-panel-mini {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.control-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.control-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
}

.ctrl-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ctrl-item {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: #f7f8fa;
  padding: 20rpx 12rpx;
  border-radius: 12rpx;
  gap: 10rpx;
}

.ctrl-icon {
  width: 56rpx;
  height: 56rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.ctrl-label {
  font-size: 24rpx;
  color: #646566;
}

.rgb-compact {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.rgb-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.rgb-title-wrapper {
  display: flex;
  align-items: center;
}

.rgb-title {
  font-size: 26rpx;
  color: #646566;
}

.rgb-modes {
  display: flex;
  gap: 12rpx;
}

.mode-btn {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  color: #646566;
  border: 1rpx solid transparent;
}

.mode-btn.active {
  background: #e8f5e9;
  color: #07c160;
  border-color: #07c160;
}

.color-presets {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
  padding: 10rpx 0;
}

.preset-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

.preset-circle:active {
  transform: scale(0.9);
}

.rgb-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.rgb-sliders {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rgb-preview-mini {
  width: 90rpx;
  height: 90rpx;
  border-radius: 16rpx;
  box-shadow: inset 0 0 8rpx rgba(0,0,0,0.1), 0 4rpx 16rpx rgba(0,0,0,0.1);
}

/* 网络配置 */
.ip-config-mini {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.rotating {
  animation: rotate 2s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
