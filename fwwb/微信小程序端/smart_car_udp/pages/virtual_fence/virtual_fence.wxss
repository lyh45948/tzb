.container {
  background: linear-gradient(180deg, #fff7e6 0%, #ffffff 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 40rpx;
}

/* 页面标题栏 */
.page-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  background: #ffffff;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(255, 151, 106, 0.1);
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #323233;
  flex: 1;
}

.header-switch {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.switch-label {
  font-size: 26rpx;
  color: #646566;
}

.connection-bar {
  background: #fff;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.connection-info {
  display: flex;
  align-items: center;
}

.connection-text {
  font-size: 26rpx;
  margin-left: 12rpx;
  color: #646566;
}

.fence-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 20rpx;
}

.config-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  box-sizing: border-box;
}

.config-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
}

.fence-type-selector {
  display: flex;
  padding: 8rpx 0;
  gap: 16rpx;
}

.fence-type-tab {
  flex: 1;
  padding: 16rpx 12rpx;
  background: #f7f8fa;
  text-align: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #646566;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s;
}

.fence-type-tab.active {
  background: linear-gradient(135deg, #ff976a 0%, #ff6b6b 100%);
  color: #fff;
}

.fence-type-tab.active van-icon {
  color: #fff !important;
}

.fence-params {
  padding: 20rpx 0 0;
}

.param-input-group {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.param-label {
  font-size: 26rpx;
  color: #646566;
  width: 100rpx;
}

.unit-text {
  font-size: 24rpx;
  color: #969799;
}

.canvas-section {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.path-canvas {
  width: 100%;
  height: 220px;
  background: #fafafa;
}

.canvas-actions {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-btn {
  width: 100rpx !important;
  font-size: 24rpx !important;
  height: 56rpx !important;
  line-height: 52rpx !important;
}

/* Joystick Compact */
.control-section {
  padding: 24rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  box-sizing: border-box;
}

.control-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.control-hint {
  font-size: 24rpx;
  color: #969799;
}

.joystick-outer {
  width: 140px;
  height: 140px;
  background: #f7f8fa;
  border-radius: 50%;
  position: relative;
  box-shadow: inset 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.joystick-container-mini {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.joystick-handle-mini {
  width: 44px;
  height: 44px;
  background: linear-gradient(135deg, #07c160, #05a351);
  border-radius: 50%;
  position: absolute;
  box-shadow: 0 6rpx 16rpx rgba(7, 193, 96, 0.3);
  border: 4rpx solid #fff;
}

.fence-list-section {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  box-sizing: border-box;
}

.fence-list-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.fence-list-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
}

.fence-count {
  margin-left: auto;
  background: #fff7e6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ff976a;
  font-weight: 500;
}

.fence-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fence-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.fence-item:active {
  background: #f0f1f2;
}

.fence-item.disabled {
  opacity: 0.5;
}

.fence-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.fence-icon {
  width: 56rpx;
  height: 56rpx;
  background: #fff7e6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fence-info {
  display: flex;
  flex-direction: column;
}

.fence-name {
  font-size: 28rpx;
  color: #323233;
  font-weight: 500;
}

.fence-sub {
  font-size: 22rpx;
  color: #ff976a;
  margin-top: 4rpx;
}

.empty-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  color: #c8c9cc;
  font-size: 26rpx;
}

.empty-status text {
  margin-top: 16rpx;
}
