/* pages/nfc/nfc.wxss */

.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4ff 0%, #ffffff 100%);
  box-sizing: border-box;
}

/* 页面标题栏 */
.page-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(25, 137, 250, 0.1);
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #323233;
}

/* 配网步骤卡片 */
.steps-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(25, 137, 250, 0.1);
  width: 100%;
  box-sizing: border-box;
}

/* WiFi配置卡片 */
.wifi-config-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(25, 137, 250, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #323233;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 表单样式 */
.wifi-form {
  margin-bottom: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.form-icon {
  width: 60rpx;
  height: 60rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.form-label {
  font-size: 24rpx;
  color: #969799;
  margin-bottom: 8rpx;
}

.form-input {
  font-size: 30rpx;
  color: #323233;
  background: transparent;
}

.input-placeholder {
  color: #c8c9cc;
}

/* 配置按钮 */
.config-button-wrapper {
  padding: 20rpx 0;
}

/* 信息卡片 */
.info-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(25, 137, 250, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.info-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
  margin-bottom: 24rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #646566;
  padding: 12rpx 0;
}
