/* pages/equipment_control/equipment_control.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.control-grid {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.control-card {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.control-card:last-child {
  border-bottom: none;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.device-name {
  font-size: 30rpx;
  color: #323233;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.device-status {
  font-size: 24rpx;
  color: #999;
}

.device-status.active {
  color: #07c160;
}

.slider-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #323233;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.slider-value {
  text-align: center;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #1989fa;
}

.status-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.status-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.status-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 12rpx;
  margin-bottom: 8rpx;
}

.status-value {
  font-size: 24rpx;
  color: #323233;
}

.status-value.active {
  color: #07c160;
  font-weight: 500;
}

.agv-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.agv-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.agv-distance {
  font-size: 28rpx;
  color: #323233;
}

.agv-indicator {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.agv-indicator.normal {
  background-color: #e8f8ea;
  color: #07c160;
}

.agv-indicator.warning {
  background-color: #ffe4e4;
  color: #ee0a24;
}

.agv-buttons {
  display: flex;
  justify-content: space-around;
}