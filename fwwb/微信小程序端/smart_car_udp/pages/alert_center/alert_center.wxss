/* pages/alert_center/alert_center.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.alert-stats {
  display: flex;
  justify-content: space-between;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
}

.stat-item.warning .stat-value {
  color: #ffc107;
}

.stat-item.danger .stat-value {
  color: #ff9800;
}

.stat-item.critical .stat-value {
  color: #ee0a24;
}

.stat-item.total .stat-value {
  color: #1989fa;
}

.alert-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #323233;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #323233;
}

.empty-subtext {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.alert-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.alert-item:last-child {
  margin-bottom: 0;
}

.alert-warning {
  background-color: #fff8c4;
}

.alert-danger {
  background-color: #ffe4b5;
}

.alert-critical {
  background-color: #ffb3b3;
}

.alert-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.alert-content {
  flex: 1;
}

.alert-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.alert-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
  margin-right: 12rpx;
}

.alert-message {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.alert-time {
  font-size: 22rpx;
  color: #999;
}

.alert-action {
  margin-left: 16rpx;
}

.history-list {
  padding: 16rpx 0;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-type {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.history-value {
  font-size: 24rpx;
  color: #323233;
  flex: 0 0 100rpx;
  text-align: center;
}

.history-time {
  font-size: 22rpx;
  color: #999;
  flex: 0 0 160rpx;
  text-align: right;
}