/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* ==================== 全局页面样式 ==================== */

/* 页面容器 - 统一背景 */
.page-container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 100%);
  box-sizing: border-box;
}

/* 页面标题栏 */
.page-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #323233;
}

/* 带状态的标题栏 */
.page-header-with-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ==================== 全局卡片样式 ==================== */

/* 全宽度卡片 */
.full-width-card {
  width: 100%;
  margin-left: 0;
  margin-right: 0;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

/* 卡片标题带图标 */
.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-header-icon {
  font-size: 36rpx;
}

.card-header-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #323233;
}

/* ==================== 全局组件样式 ==================== */

/* 状态点 */
.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.status-dot.online {
  background: #07c160;
  box-shadow: 0 0 10rpx #07c160;
}

.status-dot.offline {
  background: #969799;
}

/* 季节标签 */
.season-tag {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #ff976a 0%, #ff6b6b 100%);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 信息提示栏 */
.info-bar {
  background: linear-gradient(135deg, #e8f4ff 0%, #f0f7ff 100%);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  border-left: 4rpx solid #1989fa;
  margin-bottom: 20rpx;
}

.info-bar-text {
  font-size: 26rpx;
  color: #1989fa;
  margin-left: 12rpx;
}

/* 警告提示栏 */
.warning-bar {
  background: linear-gradient(135deg, #fff7e6 0%, #fff3cd 100%);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  border-left: 4rpx solid #ff976a;
  margin-bottom: 20rpx;
}

.warning-bar-text {
  font-size: 26rpx;
  color: #ff976a;
  margin-left: 12rpx;
}
