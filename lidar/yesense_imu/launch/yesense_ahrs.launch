<launch>
  <!-- IMU 节点 -->
  <arg name="is_visual" default="false"/>
  <node pkg="yesense_imu" type="yesense_imu_node" name="yesense_imu_node" required="true" output="screen">
    <!-- 串口设备，通过 udev 规则或符号链接固定 -->
    <param name="yesense_port" type="string" value="/dev/yesense_imu"/>
    <!-- 波特率 -->
    <param name="yesense_baudrate" type="int" value="460800"/>
    <!-- 发布的 imu 话题中的 frame_id，需与 TF 树中的 imu_link 一致 -->
    <param name="frame_id" type="string" value="imu_link"/>
    <!-- 协方差参数：robot_pose_ekf 需要非零值才能使用 IMU 数据 -->
    <param name="orientation_stddev" value="0.05"/>
    <param name="angular_velocity_stddev" value="0.02"/>
    <param name="linear_acceleration_stddev" value="0.1"/>
    <!-- 发布的 imu 话题名 -->
    <param name="imu_topic" value="imu"/>
  </node>
  <include file="$(find yesense_imu)/launch/tf.launch" if="$(arg is_visual)"/>
</launch>
