<launch>
    <node pkg="imu_utils" type="imu_an" name="imu_an" output="screen">
        <param name="imu_topic" type="string" value= "/imu"/> <!-- 订阅的imu数据话题名称 -->
        <param name="imu_name" type="string" value= "A3"/> <!-- imu名字，任意设置即可 -->
        <param name="data_save_path" type="string" value= "$(find imu_utils)/data/"/> <!-- 标定结果文件存放位置 -->
        <param name="max_time_min" type="int" value= "120"/> <!-- 标定时长，单位：分钟 -->
        <param name="max_cluster" type="int" value= "100"/> <!-- 默认值 -->
    </node>
</launch>
